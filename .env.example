# ================================================================
# INSTRUÇÕES RÁPIDAS:
# ================================================================
# 1. DESENVOLVIMENTO LOCAL (sem Docker):
#    DATABASE_URL=postgresql://usuario:senha@localhost:5432/chatbot_imobiliaria
#
# 2. COM DOCKER COMPOSE:
#    DATABASE_URL=postgresql://chatbot_user:chatbot_secure_password_123@postgres:5432/chatbot_imobiliaria
#    (Docker usa o hostname "postgres" ao invés de "localhost")
# ================================================================

# ============================================================
# WHATSAPP - Meta Cloud API
# https://developers.facebook.com/docs/whatsapp/cloud-api
# ============================================================
# Token de acesso gerado no Meta Business Suite / App Dashboard
WHATSAPP_ACCESS_TOKEN=

# ID do número de telefone do WhatsApp Business
# Encontrado em: Meta for Developers > seu App > WhatsApp > Configuração
WHATSAPP_PHONE_NUMBER_ID=

# Token de verificação do webhook (você define este valor, qualquer string)
WHATSAPP_VERIFY_TOKEN=meu_token_secreto_aqui

# Versão da API do Graph (manter v20.0 ou superior)
WHATSAPP_API_VERSION=v20.0

# ============================================================
# OPENAI - GPT-4
# https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=

# Modelo a ser usado (gpt-4o é o mais atualizado e econômico)
OPENAI_MODEL=gpt-4o

# ============================================================
# SR PROPRIETÁRIO API
# Solicitar ao suporte do SR Proprietário
# ============================================================
SR_PROPRIETARIO_API_URL=https://api.srproprietario.com.br
SR_PROPRIETARIO_API_KEY=

# ============================================================
# IMOVIEW CRM API
# Obter em: IMOVIEW CRM > Integrações > API
# ============================================================
IMOVIEW_API_URL=https://api.imoview.com.br
IMOVIEW_API_KEY=

# ID da imobiliária no IMOVIEW (verificar no painel)
IMOVIEW_EMPRESA_ID=

# ============================================================
# BANCO DE DADOS - PostgreSQL
# ============================================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/chatbot_imobiliaria

# ============================================================
# SERVIDOR
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# CONFIGURAÇÕES DO CHATBOT
# ============================================================
# Nome da imobiliária (aparece nas mensagens)
EMPRESA_NOME=Minha Imobiliária

# Cidade principal de atuação
EMPRESA_CIDADE=Belo Horizonte

# Número de imóveis máximo por resposta
MAX_IMOVEIS_POR_RESPOSTA=3

# Tempo máximo de inatividade antes de encerrar conversa (em minutos)
CONVERSA_TIMEOUT_MINUTOS=60
