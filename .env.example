# ============================================================
# Template de variáveis de ambiente
#
# Desenvolvimento local:
#   cp .env.example .env
#   # ajuste os valores marcados com [DEV] conforme necessário
#
# Produção (Oracle VM):
#   # copie e preencha TODOS os valores marcados com [PROD]
#   # os valores marcados [DEV] geralmente ficam com o padrão de produção
# ============================================================

# ----- Servidor -----
# [DEV]  development | [PROD] production
NODE_ENV=development
PORT=3000
# Nível de log (error | warn | info | http | debug).
# Padrão automático: debug em development, info em production.
# LOG_LEVEL=debug

# ----- Banco de dados (PostgreSQL) -----
# [DEV]  aponta para localhost (sem Docker) ou para o serviço "postgres" do compose
# [PROD] aponta para o serviço interno do compose (nunca exposto externamente)
DATABASE_URL=postgresql://chatbot_user:chatbot_password@localhost:5432/chatbot_imobiliaria

# Usadas pelo docker-compose para provisionar o container do Postgres:
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=chatbot_password
POSTGRES_DB=chatbot_imobiliaria
POSTGRES_PORT=5432

# ----- WhatsApp — provider -----
# 'meta'   → Meta Cloud API (produção — obrigatório em prod)
# 'uazapi' → uazapi.dev cloud gratuito (recomendado para dev/testes)
# [DEV]  uazapi  |  [PROD] meta (sobrescrito automaticamente pelo docker-compose.prod.yml)
WHATSAPP_PROVIDER=uazapi

# ----- WhatsApp — Meta Cloud API -----
# [DEV]  pode deixar vazio — com SKIP_WHATSAPP_SEND=true as credenciais não são exigidas.
#        O app sobe normalmente e loga as respostas em vez de enviá-las ao WhatsApp.
# [PROD] obrigatório — https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token de verificação do webhook (você define, qualquer string segura).
# Padrão automático em dev: "local-dev"
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
# App Secret — habilita verificação da assinatura X-Hub-Signature-256 (recomendado em prod).
WHATSAPP_APP_SECRET=

# ----- uazapi (WHATSAPP_PROVIDER=uazapi) -----
# Acesse https://uazapi.dev → crie uma instância gratuita → conecte seu WhatsApp via QR code.
# Configure o webhook da instância para: https://SEU-NGROK.ngrok-free.app/webhook
# Instâncias do plano gratuito expiram após 1 hora; recrie quando necessário.
UAZAPI_BASE_URL=https://free.uazapi.com
UAZAPI_INSTANCE_TOKEN=

# ----- OpenAI -----
# [DEV]  pode deixar vazio com USE_MOCK_AI=true (sem custo)
# [PROD] obrigatório — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# true → usa respostas simuladas (sem custo, sem API key).
# Padrão automático: true quando OPENAI_API_KEY está vazio.
USE_MOCK_AI=true

# ----- IMOVIEW (catálogo de imóveis + CRM) -----
# [DEV/PROD] Opcional: se não configurado, usa catálogo de exemplo embutido e
#            leads ficam apenas no banco local.
# Chave de acesso fornecida pela Universal Software.
IMOVIEW_API_URL=https://api.imoview.com.br
IMOVIEW_API_KEY=
IMOVIEW_EMPRESA_ID=

# ----- Comportamento -----
# [DEV]  true → não envia mensagens ao WhatsApp, apenas loga (ideal para dev/testes)
# [PROD] false (sobrescrito automaticamente pelo docker-compose.prod.yml)
SKIP_WHATSAPP_SEND=true

# true → bloqueia perguntas fora do escopo imobiliário antes de chamar o LLM principal.
# [DEV]  pode deixar true (MockAiService.classify retorna sempre true, sem custo)
# [PROD] true (recomendado — usa gpt-4o-mini para classificar, custo mínimo por mensagem)
TOPIC_GUARD_ENABLED=true

# ----- Chatbot -----
EMPRESA_NOME=Minha Imobiliária
EMPRESA_CIDADE=Belo Horizonte
MAX_IMOVEIS_POR_RESPOSTA=3
CONVERSA_TIMEOUT_MINUTOS=60
CONVERSATION_CLEANUP_INTERVAL_MINUTES=60
