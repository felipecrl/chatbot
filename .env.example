# ============================================================
# Copie este arquivo para `.env` e preencha os valores.
#   cp .env.example .env
# ============================================================

# ----- Servidor -----
NODE_ENV=development
PORT=3000
# Nível de log (error | warn | info | http | debug). Padrão: debug em dev, info em prod.
# LOG_LEVEL=debug

# ----- Banco de dados (PostgreSQL) -----
# Local (sem Docker):  postgresql://usuario:senha@localhost:5432/chatbot_imobiliaria
# Com docker-compose:  postgresql://chatbot_user:chatbot_password@postgres:5432/chatbot_imobiliaria
DATABASE_URL=postgresql://chatbot_user:chatbot_password@localhost:5432/chatbot_imobiliaria

# Variáveis usadas apenas pelo docker-compose para provisionar o container do Postgres:
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=chatbot_password
POSTGRES_DB=chatbot_imobiliaria
POSTGRES_PORT=5432

# ----- WhatsApp — Meta Cloud API -----
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token de verificação do webhook (você define, qualquer string).
WHATSAPP_VERIFY_TOKEN=troque_este_token
WHATSAPP_API_VERSION=v20.0
# App Secret do app na Meta — habilita a verificação da assinatura X-Hub-Signature-256 (recomendado).
WHATSAPP_APP_SECRET=

# ----- OpenAI -----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# true para usar respostas simuladas (sem custo) — padrão: true quando OPENAI_API_KEY está vazio.
# USE_MOCK_AI=false

# ----- SR Proprietário (catálogo de imóveis) -----
# Opcional: se não configurado, é usado um catálogo de exemplo embutido.
SR_PROPRIETARIO_API_URL=https://api.srproprietario.com.br
SR_PROPRIETARIO_API_KEY=

# ----- IMOVIEW CRM -----
# Opcional: se não configurado, os leads ficam apenas no banco local.
IMOVIEW_API_URL=https://api.imoview.com.br
IMOVIEW_API_KEY=
IMOVIEW_EMPRESA_ID=

# ----- Comportamento (úteis em testes locais) -----
# true para não enviar mensagens ao WhatsApp (apenas loga as respostas).
SKIP_WHATSAPP_SEND=false

# ----- Chatbot -----
EMPRESA_NOME=Minha Imobiliária
EMPRESA_CIDADE=Belo Horizonte
MAX_IMOVEIS_POR_RESPOSTA=3
CONVERSA_TIMEOUT_MINUTOS=60
CONVERSATION_CLEANUP_INTERVAL_MINUTES=60
